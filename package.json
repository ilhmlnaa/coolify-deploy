{
  "name": "coolify-deploy",
  "version": "1.0.0",
  "description": "Deploy to Coolify with optional Cloudflare Bot Fight Mode bypass and GitHub Deployments",
  "main": "src/main.js",
  "scripts": {
    "build": "npm run build:main && npm run build:post",
    "build:main": "ncc build src/main.js -o dist/main",
    "build:post": "ncc build src/post.js -o dist/post",
    "lint": "eslint src/"
  },
  "keywords": [
    "github-action",
    "coolify",
    "deploy",
    "cloudflare",
    "bot-fight-mode"
  ],
  "author": "ilhmlnaa",
  "license": "MIT",
  "dependencies": {
    "@actions/core": "^1.10.1",
    "@actions/github": "^6.0.0",
    "@actions/http-client": "^2.2.0"
  },
  "devDependencies": {
    "@vercel/ncc": "^0.38.0",
    "eslint": "^8.0.0"
  }
}
